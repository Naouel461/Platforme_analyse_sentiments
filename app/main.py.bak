# Garde seulement celle-ci :
app_sentiment = FastAPI()

# Config CORS
ALLOWED_URLS = [
    "http://localhost:3000",
    "http://127.0.0.1:3000",
    "http://localhost:8000"
]

app_sentiment.add_middleware(
    CORS_Plug,
    allow_origins=ALLOWED_URLS,
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

